# =============================================================================
# .htaccess — financialQ Landing SPA
# Compatible con Apache 2.4+ y LiteSpeed (Hostinger)
#
# PROBLEMA QUE RESUELVE:
#   Apache busca archivos físicos para cada URL. Una SPA tiene un único archivo
#   real (index.html); todas las rutas son virtuales manejadas por React Router
#   en el cliente. Sin este archivo, cualquier refresh en /sobre/firma devuelve
#   404 porque Apache no encuentra ese directorio en disco.
#
# ARQUITECTURA DE LAS REGLAS (orden obligatorio):
#   1. HTTPS redirect  — debe ir PRIMERO; opera sobre la petición original
#   2. SPA fallback    — opera sobre la URI ya segura
#   Tener dos bloques <IfModule mod_rewrite.c> separados rompe este orden:
#   el flag [L] solo detiene el bloque actual, no los bloques siguientes.
#   Por eso TODO el rewrite va en UN único bloque.
# =============================================================================


# ------------------------------------------------------------------------------
# 1. REESCRITURA — bloque único con orden garantizado
# ------------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Base de URL. Cambia a /subdir/ si la app no está en la raíz del dominio.
  RewriteBase /

  # --------------------------------------------------------------------------
  # 1a. FORZAR HTTPS
  #     Redirige HTTP → HTTPS antes de cualquier otra regla.
  #     Activo solo cuando %{HTTPS} es "off" (petición HTTP plana).
  #
  #     IMPORTANTE: descomenta esta sección solo cuando el certificado SSL
  #     esté instalado y activo en Hostinger. Con HTTP, la redirección
  #     crea un bucle infinito o un 404 silencioso.
  #
     RewriteCond %{HTTPS} off
     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
  # --------------------------------------------------------------------------

  # --------------------------------------------------------------------------
  # 1b. EXCLUIR ARCHIVOS Y DIRECTORIOS REALES
  #     Si la petición apunta a un recurso físico que SÍ existe en disco
  #     (JS, CSS, PNG, webmanifest, etc.), Apache lo sirve directamente.
  #     Sin esta regla, los assets de /assets/ también irían a index.html
  #     y la app no cargaría.
  #
  #     -f = es un archivo real   |   -d = es un directorio real
  #     [OR] = condición A ó condición B
  # --------------------------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # --------------------------------------------------------------------------
  # 1c. FALLBACK AL INDEX.HTML — regla central de la SPA
  #     Cualquier petición que llegue aquí NO existe en disco.
  #     Ejemplos: /sobre/firma, /approach/philosophy, /clientes
  #
  #     La reescritura entrega index.html al browser SIN cambiar la URL
  #     visible (diferente de una redirección 301/302). React Router lee
  #     window.location y renderiza el componente correcto.
  #
  #     [L]   = Last rule: detiene este ruleset
  #     [QSA] = Query String Append: preserva ?utm_source=... si los hay
  # --------------------------------------------------------------------------
  RewriteRule ^ index.html [L,QSA]

</IfModule>


# ------------------------------------------------------------------------------
# 2. CABECERAS DE CACHÉ — estrategia "cache-busting" para SPA con Vite
#
#    Vite genera hashes de contenido en los nombres de archivo:
#      index-DTlALgzF.js  →  si el código cambia, el nombre cambia
#    Esto permite cache agresivo en assets sin riesgo de contenido obsoleto.
#
#    index.html NO tiene hash → debe revalidarse siempre para que el browser
#    descubra los nuevos nombres de assets tras cada deploy.
# ------------------------------------------------------------------------------
<IfModule mod_headers.c>

  # -- index.html: nunca cachear --
  #    "no-store" impide guardar cualquier copia (memoria o disco).
  #    "must-revalidate" fuerza al browser a preguntar al servidor.
  #    Resultado: tras un deploy, los usuarios obtienen los nuevos hashes
  #    de JS/CSS de inmediato, sin hard-refresh manual.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma        "no-cache"
    Header set Expires       "0"
  </FilesMatch>

  # -- JS y CSS con hash: cache máximo (1 año) --
  #    "immutable" le dice al browser que ni siquiera intente revalidar.
  #    Seguro porque el hash en el nombre cambia si el contenido cambia.
  <FilesMatch "\.(js|mjs|css|woff2|woff|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # -- Imágenes: cache de 30 días --
  #    Más conservador porque pueden actualizarse con el mismo nombre
  #    (logos, og-image, etc.).
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # -- PDFs: cache de 7 días --
  <FilesMatch "\.pdf$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # -- WebManifest: sin cache (puede cambiar con el tema/iconos de la PWA) --
  <FilesMatch "\.webmanifest$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # -- Cabeceras de seguridad --

  # Impide que el browser adivine el MIME type (previene MIME-sniffing attacks)
  Header set X-Content-Type-Options  "nosniff"

  # Clickjacking: solo permite embeber la app desde el mismo origen
  Header set X-Frame-Options         "SAMEORIGIN"

  # XSS filter legacy (útil para IE/Edge antiguos)
  Header set X-XSS-Protection        "1; mode=block"

  # Referrer: envía el origen completo solo en peticiones al mismo dominio
  Header set Referrer-Policy         "strict-origin-when-cross-origin"

  # HSTS: descomenta SOLO cuando SSL esté activo y probado.
  # Una vez enviado, el browser bloquea HTTP durante 1 año. No hay rollback.
  # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

</IfModule>


# ------------------------------------------------------------------------------
# 3. TIPOS MIME — corregir interpretación de formatos modernos
#
#    LiteSpeed/Apache en configuraciones mínimas puede no tener registrados
#    estos MIME types. Sin ellos, el browser puede rechazar o ignorar assets.
# ------------------------------------------------------------------------------
<IfModule mod_mime.c>
  # Módulos ES (type="module" en los scripts generados por Vite)
  AddType application/javascript   .js .mjs

  # JSON — explícito para evitar que LiteSpeed lo sirva como text/plain
  AddType application/json         .json

  # WebManifest
  AddType application/manifest+json .webmanifest

  # Fuentes web modernas
  AddType font/woff2               .woff2
  AddType font/woff                .woff

  # SVG
  AddType image/svg+xml            .svg

  # Imágenes de nueva generación
  AddType image/webp               .webp
  AddType image/avif               .avif
</IfModule>


# ------------------------------------------------------------------------------
# 4. COMPRESIÓN GZIP
#    Reduce el tamaño de transferencia de JS y CSS entre 60–80 %.
#    Hostinger habilita mod_deflate en todos los planes compartidos.
# ------------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>
